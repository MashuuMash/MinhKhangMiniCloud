$ORIGIN cloud.local.
$TTL 1H
@   IN SOA  ns.cloud.local. admin.cloud.local. (
        2024040701 ; serial
        1H         ; refresh
        15M        ; retry
        1W         ; underscore
        1H         ; TTL
    )
@   IN NS   ns.cloud.local.
ns  IN A    127.0.0.1
web-frontend-server IN A 10.10.10.10
application-backend-server IN A 10.10.10.20
